{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopSession",
  "type": "object",
  "required": [
    "id",
    "started_at",
    "finished_at",
    "requested_steps",
    "completed_steps",
    "stopped_reason",
    "persist",
    "stop_on_rejection",
    "committed_count",
    "rejected_count",
    "failed_count",
    "first_chapter_index",
    "last_chapter_index",
    "last_run_id",
    "recovery_links",
    "runs"
  ],
  "properties": {
    "book_id": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "requested_steps": {
      "type": "integer",
      "minimum": 1
    },
    "completed_steps": {
      "type": "integer",
      "minimum": 0
    },
    "stopped_reason": {
      "enum": [
        "max_steps",
        "rejected",
        "failed"
      ]
    },
    "persist": {
      "type": "boolean"
    },
    "stop_on_rejection": {
      "type": "boolean"
    },
    "succeeded": {
      "type": "boolean"
    },
    "exit_code": {
      "enum": [0, 1]
    },
    "failure_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "committed_count": {
      "type": "integer",
      "minimum": 0
    },
    "rejected_count": {
      "type": "integer",
      "minimum": 0
    },
    "failed_count": {
      "type": "integer",
      "minimum": 0
    },
    "first_chapter_index": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "last_chapter_index": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "last_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "committed",
          "chapter_index",
          "problem_codes",
          "repair_attempts"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "enum": [
              "preview",
              "committed",
              "rejected",
              "failed"
            ]
          },
          "accepted": {
            "type": "boolean"
          },
          "committed": {
            "type": "boolean"
          },
          "failure_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "chapter_index": {
            "type": "integer",
            "minimum": 1
          },
          "problem_codes": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "problem_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "code",
                "validator",
                "severity",
                "blocking",
                "repair_action",
                "evidence"
              ],
              "properties": {
                "code": {
                  "type": "string"
                },
                "validator": {
                  "type": "string"
                },
                "severity": {
                  "enum": [
                    "critical",
                    "high",
                    "medium",
                    "low"
                  ]
                },
                "blocking": {
                  "type": "boolean"
                },
                "repair_action": {
                  "enum": [
                    "seed_conflict_scene",
                    "expand_scene",
                    "add_conflict_signal",
                    "remove_forbidden_term",
                    "add_required_term",
                    "anchor_known_location",
                    "insert_opening_bridge",
                    "rewrite_spatial_transition",
                    "anchor_last_scene_state",
                    "repair_character_position",
                    "add_transition_event",
                    "flag_unknown_location",
                    "add_character_location",
                    "rewrite_inactive_character_action",
                    "correct_chapter_index",
                    "manual_review"
                  ]
                },
                "evidence": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "kind",
                      "value"
                    ],
                    "properties": {
                      "kind": {
                        "type": "string",
                        "minLength": 1
                      },
                      "value": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "requested_focus": {
            "type": "array",
            "items": {
              "enum": [
                "continuity",
                "spatial",
                "logic",
                "story_project",
                "llm"
              ]
            }
          },
          "executed_checks": {
            "type": "array",
            "items": {
              "enum": [
                "continuity",
                "spatial",
                "logic",
                "story_project",
                "llm"
              ]
            }
          },
          "skipped_checks": {
            "type": "array",
            "items": {
              "enum": [
                "continuity",
                "spatial",
                "logic",
                "story_project",
                "llm"
              ]
            }
          },
          "workflow_actions": {
            "type": "array",
            "items": {
              "enum": [
                "build_snapshot",
                "pre_validate_bridge",
                "generate_chapter",
                "polish",
                "validate",
                "repair_if_needed",
                "commit_snapshot"
              ]
            }
          },
          "trace_actions": {
            "type": "array",
            "items": {
              "enum": [
                "build_snapshot",
                "pre_validate_bridge",
                "generate_chapter",
                "polish",
                "validate",
                "repair_if_needed",
                "commit_snapshot"
              ]
            }
          },
          "trace_plan_aligned": {
            "type": "boolean"
          },
          "repair_attempts": {
            "type": "integer",
            "minimum": 0
          },
          "repair_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "code",
                "validator",
                "action",
                "evidence"
              ],
              "properties": {
                "code": {
                  "type": "string"
                },
                "validator": {
                  "type": "string"
                },
                "action": {
                  "enum": [
                    "seed_conflict_scene",
                    "expand_scene",
                    "add_conflict_signal",
                    "remove_forbidden_term",
                    "add_required_term",
                    "anchor_known_location",
                    "insert_opening_bridge",
                    "rewrite_spatial_transition",
                    "anchor_last_scene_state",
                    "repair_character_position",
                    "add_transition_event",
                    "flag_unknown_location",
                    "add_character_location",
                    "rewrite_inactive_character_action",
                    "correct_chapter_index",
                    "manual_review"
                  ]
                },
                "evidence": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "kind",
                      "value"
                    ],
                    "properties": {
                      "kind": {
                        "type": "string",
                        "minLength": 1
                      },
                      "value": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "step_timings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step",
          "status",
          "started_at",
          "finished_at",
          "duration_ms"
        ],
        "properties": {
          "step": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "enum": [
              "preview",
              "committed",
              "rejected",
              "failed"
            ]
          },
          "started_at": {
            "type": "string"
          },
          "finished_at": {
            "type": "string"
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0
          },
          "run_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "chapter_index": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "committed": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "error_type": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "recovery_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "run_id",
          "run_status",
          "director_goal",
          "source_run_id",
          "source_status",
          "source_chapter_index",
          "source_problem_codes",
          "repair_stalled",
          "repair_introduced_new_problems",
          "repair_risk_level",
          "repair_budget_exhausted"
        ],
        "properties": {
          "run_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "run_status": {
            "enum": [
              "preview",
              "committed",
              "rejected",
              "failed"
            ]
          },
          "director_goal": {
            "type": [
              "string",
              "null"
            ]
          },
          "source_run_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "source_status": {
            "type": [
              "string",
              "null"
            ]
          },
          "source_chapter_index": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "source_problem_codes": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "repair_stalled": {
            "type": "boolean"
          },
          "repair_introduced_new_problems": {
            "type": "boolean"
          },
          "repair_risk_level": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "none",
              null
            ]
          },
          "repair_budget_exhausted": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "artifact": {
      "type": "object"
    },
    "error": {
      "type": "object",
      "required": [
        "type",
        "message"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "code": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
