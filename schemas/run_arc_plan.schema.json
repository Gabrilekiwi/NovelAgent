{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunArcPlan",
  "type": "object",
  "required": ["schema_version", "arc_plan_id", "arc_plan_hash", "instruction_plan_id", "instruction_plan_hash", "session_id", "book_id", "source_snapshot_hash", "chapter_start", "chapter_end", "revision", "previous_arc_plan_hash", "targets", "adjustments", "created_at", "updated_at"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "arc_plan_id": {"type": "string", "minLength": 1},
    "arc_plan_hash": {"type": "string", "minLength": 64},
    "instruction_plan_id": {"type": "string", "minLength": 1},
    "instruction_plan_hash": {"type": "string", "minLength": 64},
    "session_id": {"type": "string", "minLength": 1},
    "book_id": {"type": "string", "minLength": 1},
    "source_snapshot_hash": {"type": "string", "minLength": 64},
    "chapter_start": {"type": "integer", "minimum": 1},
    "chapter_end": {"type": "integer", "minimum": 1},
    "revision": {"type": "integer", "minimum": 1},
    "previous_arc_plan_hash": {"type": ["string", "null"], "minLength": 64},
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["chapter_index", "planned", "target_hash", "fulfilled", "differences", "completion_receipt_hash", "adjustment_note"],
        "properties": {
          "chapter_index": {"type": "integer", "minimum": 1},
          "planned": {
            "type": "object",
            "required": ["mainline", "relationship", "escalation", "resource_cost", "foreshadowing"],
            "properties": {
              "mainline": {"type": "string", "minLength": 1},
              "relationship": {"type": "string", "minLength": 1},
              "escalation": {"type": "string", "minLength": 1},
              "resource_cost": {"type": "string", "minLength": 1},
              "foreshadowing": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          },
          "target_hash": {"type": "string", "minLength": 64},
          "fulfilled": {
            "type": ["object", "null"],
            "required": ["mainline", "relationship", "escalation", "resource_cost", "foreshadowing"],
            "properties": {
              "mainline": {"type": "string", "minLength": 1},
              "relationship": {"type": "string", "minLength": 1},
              "escalation": {"type": "string", "minLength": 1},
              "resource_cost": {"type": "string", "minLength": 1},
              "foreshadowing": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          },
          "differences": {"type": "array", "items": {"type": "string", "enum": ["mainline", "relationship", "escalation", "resource_cost", "foreshadowing"]}},
          "completion_receipt_hash": {"type": ["string", "null"], "minLength": 64},
          "adjustment_note": {"type": ["string", "null"], "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "adjustments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["revision", "chapter_index", "before", "after", "reason", "recorded_at"],
        "properties": {
          "revision": {"type": "integer", "minimum": 1},
          "chapter_index": {"type": "integer", "minimum": 1},
          "before": {
            "type": "object",
            "required": ["mainline", "relationship", "escalation", "resource_cost", "foreshadowing"],
            "properties": {
              "mainline": {"type": "string", "minLength": 1},
              "relationship": {"type": "string", "minLength": 1},
              "escalation": {"type": "string", "minLength": 1},
              "resource_cost": {"type": "string", "minLength": 1},
              "foreshadowing": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          },
          "after": {
            "type": "object",
            "required": ["mainline", "relationship", "escalation", "resource_cost", "foreshadowing"],
            "properties": {
              "mainline": {"type": "string", "minLength": 1},
              "relationship": {"type": "string", "minLength": 1},
              "escalation": {"type": "string", "minLength": 1},
              "resource_cost": {"type": "string", "minLength": 1},
              "foreshadowing": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          },
          "reason": {"type": "string", "minLength": 1},
          "recorded_at": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "created_at": {"type": "string", "minLength": 1},
    "updated_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
