{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextBudgetReport",
  "type": "object",
  "required": ["schema_version", "stage", "provider", "model", "model_context_window", "usable_input_tokens", "hard_input_limit", "raw_input_tokens", "budgeted_input_tokens", "count_mode", "counter_version", "within_budget", "context_digest"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "stage": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "model_context_window": {"type": "integer", "minimum": 1},
    "usable_input_tokens": {"type": "integer", "minimum": 0},
    "hard_input_limit": {"type": "integer", "minimum": 0},
    "raw_input_tokens": {"type": "integer", "minimum": 0},
    "budgeted_input_tokens": {"type": "integer", "minimum": 0},
    "count_mode": {"type": "string", "enum": ["provider_exact", "model_tokenizer", "calibrated_estimate", "exact", "estimate"]},
    "counter_version": {"type": "string", "minLength": 1},
    "count_metadata": {
      "type": "object",
      "required": ["provider", "model", "endpoint_type", "model_is_known", "counter_source"],
      "properties": {
        "provider": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "endpoint_type": {"type": "string", "enum": ["official", "openai_compatible", "unknown"]},
        "model_is_known": {"type": "boolean"},
        "counter_source": {"type": "string", "enum": ["provider_usage", "tokenizer", "calibration"]},
        "tokenizer": {"type": "string", "minLength": 1},
        "tokenizer_version": {"type": "string", "minLength": 1},
        "provider_counter_version": {"type": "string", "minLength": 1},
        "calibration_version": {"type": "string", "minLength": 1},
        "calibration_source": {"type": "string", "minLength": 1},
        "calibration_manifest_hash": {"type": "string", "minLength": 64},
        "holdout_manifest_hash": {"type": "string", "minLength": 64},
        "holdout_role": {"type": "string", "enum": ["evaluation_only"]},
        "calibration_real_provider_verified": {"type": "boolean"},
        "calibration_method": {"type": "string", "minLength": 1},
        "calibration_tokens_per_utf8_byte": {"type": "number", "minimum": 0},
        "enforcement_method": {"type": "string", "minLength": 1},
        "enforcement_floor_tokens_per_utf8_byte": {"type": "number", "minimum": 0},
        "ascii_floor_tokens_per_byte": {"type": "number", "minimum": 0},
        "enforcement_fixed_overhead_tokens": {"type": "integer", "minimum": 0},
        "enforcement_safety_ratio": {"type": "number", "minimum": 0},
        "ascii_floor_applied": {"type": "boolean"},
        "tokenizer_fixed_overhead_tokens": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "within_budget": {"type": "boolean"},
    "context_digest": {"type": "string", "minLength": 64}
  },
  "additionalProperties": false
}
