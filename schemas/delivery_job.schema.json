{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeliveryJob",
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "book_id",
    "run_id",
    "publication_receipt_hash",
    "operation_id",
    "target_type",
    "target",
    "payload",
    "payload_hash",
    "policy",
    "state",
    "lease",
    "attempt_count",
    "last_attempt_receipt",
    "uncertain_since",
    "confirmed_absent_at",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "job_id": {"type": "string", "minLength": 1},
    "book_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "publication_receipt_hash": {"type": "string", "minLength": 64},
    "operation_id": {"type": "string", "minLength": 1},
    "target_type": {"type": "string", "enum": ["none", "file", "notion"]},
    "target": {"type": "object", "additionalProperties": true},
    "payload": {"type": "object", "additionalProperties": true},
    "payload_hash": {"type": "string", "minLength": 64},
    "policy": {"type": "string", "enum": ["not_required", "required", "best_effort"]},
    "state": {
      "type": "string",
      "enum": [
        "not_required",
        "pending",
        "delivering",
        "succeeded",
        "retryable_failed",
        "permanent_failed",
        "uncertain",
        "conflict",
        "cancelled"
      ]
    },
    "lease": {"type": ["object", "null"]},
    "attempt_count": {"type": "integer", "minimum": 0},
    "last_attempt_receipt": {"type": ["object", "null"]},
    "uncertain_since": {"type": ["string", "null"]},
    "confirmed_absent_at": {"type": ["string", "null"]},
    "created_at": {"type": "string", "minLength": 1},
    "updated_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
