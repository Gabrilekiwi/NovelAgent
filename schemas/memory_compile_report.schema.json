{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryCompileReport",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "memory_path",
    "output_dir",
    "reset",
    "dry_run",
    "input",
    "patch",
    "canonical_memory",
    "events",
    "snapshot_preview",
    "outputs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "2.0",
        "2.1"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "memory_path": {
      "type": "string",
      "minLength": 1
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "reset": {
      "type": "boolean"
    },
    "dry_run": {
      "type": "boolean"
    },
    "input": {
      "type": "object"
    },
    "patch": {
      "type": "object",
      "required": [
        "patch_id",
        "operation_count",
        "operation_types"
      ],
      "properties": {
        "patch_id": {
          "type": "string",
          "minLength": 1
        },
        "operation_count": {
          "type": "integer",
          "minimum": 0
        },
        "operation_types": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "canonical_memory": {
      "type": "object",
      "required": [
        "path",
        "previous_revision",
        "revision",
        "character_count",
        "location_count",
        "timeline_count",
        "constraint_count",
        "open_thread_count"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "previous_revision": {
          "type": "integer",
          "minimum": 1
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "character_count": {
          "type": "integer",
          "minimum": 0
        },
        "location_count": {
          "type": "integer",
          "minimum": 0
        },
        "timeline_count": {
          "type": "integer",
          "minimum": 0
        },
        "constraint_count": {
          "type": "integer",
          "minimum": 0
        },
        "open_thread_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "events": {
      "type": "object",
      "required": [
        "path",
        "event_count",
        "first_revision",
        "last_revision"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "event_count": {
          "type": "integer",
          "minimum": 0
        },
        "first_revision": {
          "type": "integer",
          "minimum": 0
        },
        "last_revision": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "snapshot_preview": {
      "type": "object"
    },
    "outputs": {
      "type": "object",
      "required": [
        "canonical_memory",
        "memory_events",
        "memory_patch",
        "snapshot_preview",
        "memory_compile_report"
      ],
      "properties": {
        "canonical_memory": {
          "type": "string"
        },
        "memory_events": {
          "type": "string"
        },
        "memory_patch": {
          "type": "string"
        },
        "snapshot_preview": {
          "type": "string"
        },
        "memory_compile_report": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
