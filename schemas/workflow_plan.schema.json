{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowPlan",
  "type": "object",
  "required": ["goal", "actions", "steps", "validation_focus", "max_repair_attempts", "recovery"],
  "properties": {
    "goal": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["generate_chapter", "polish", "validate", "repair_if_needed"]
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "index",
          "action",
          "requires",
          "produces",
          "purpose",
          "mode",
          "skippable",
          "skip_condition",
          "failure_policy"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "enum": ["generate_chapter", "polish", "validate", "repair_if_needed"]
          },
          "requires": {
            "type": "array",
            "items": {
              "enum": ["chapter", "validation"]
            }
          },
          "produces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": ["chapter", "validation"]
            }
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "enum": ["required", "optional", "conditional"]
          },
          "skippable": {
            "type": "boolean"
          },
          "skip_condition": {
            "type": ["string", "null"]
          },
          "failure_policy": {
            "enum": ["fail_run"]
          }
        },
        "additionalProperties": false
      }
    },
    "validation_focus": {
      "type": "array",
      "items": {
        "enum": ["continuity", "spatial", "logic"]
      }
    },
    "max_repair_attempts": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "recovery": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
