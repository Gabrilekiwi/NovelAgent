{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterPipeline",
  "type": "object",
  "required": ["chapter_index", "plan", "scene_drafts", "merged_chapter", "scene_spans", "stages"],
  "properties": {
    "chapter_index": {
      "type": "integer",
      "minimum": 1
    },
    "plan": {
      "type": "object",
      "required": ["goal", "scenes"],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "scenes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["index", "goal", "required_beats"],
            "properties": {
              "index": {
                "type": "integer",
                "minimum": 1
              },
              "goal": {
                "type": "string",
                "minLength": 1
              },
              "required_beats": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "scene_drafts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["index", "goal", "text"],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 1
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "merged_chapter": {
      "type": "string",
      "minLength": 1
    },
    "scene_spans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["index", "start_char", "end_char", "chars"],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 1
          },
          "start_char": {
            "type": "integer",
            "minimum": 0
          },
          "end_char": {
            "type": "integer",
            "minimum": 1
          },
          "chars": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    },
    "stages": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "plan_chapter",
              "generate_scenes",
              "merge_scenes",
              "validate",
              "repair",
              "commit"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "completed", "skipped", "failed"]
          },
          "artifact_key": {
            "type": "string",
            "enum": [
              "plan",
              "scene_drafts",
              "merged_chapter",
              "validation_report",
              "repair_deltas",
              "chapter"
            ]
          },
          "summary": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
