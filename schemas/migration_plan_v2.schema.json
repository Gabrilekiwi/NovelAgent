{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MigrationPlanV2",
  "type": "object",
  "required": ["schema_version", "plan_id", "plan_hash", "book_id", "expected_identity_sha256", "source_digest", "sources", "conflicts", "required_decisions", "evidence_summary", "created_at"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["2.0"]},
    "plan_id": {"type": "string", "minLength": 1},
    "plan_hash": {"type": "string", "minLength": 64},
    "book_id": {"type": "string", "minLength": 1},
    "expected_identity_sha256": {"type": "string", "minLength": 64},
    "source_digest": {"type": "string", "minLength": 64},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relative_path", "role", "sha256", "size", "evidence_class", "chapter_index"],
        "properties": {
          "relative_path": {"type": "string", "minLength": 1},
          "role": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "minLength": 64},
          "size": {"type": "integer", "minimum": 0},
          "evidence_class": {"type": "string", "enum": ["occurred_event", "static_constraint", "unknown", "identity", "legacy_artifact"]},
          "chapter_index": {"type": ["integer", "null"], "minimum": 1}
        },
        "additionalProperties": false
      }
    },
    "conflicts": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "required_decisions": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
    "evidence_summary": {"type": "object", "additionalProperties": true},
    "created_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
