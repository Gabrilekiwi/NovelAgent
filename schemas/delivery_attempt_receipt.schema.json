{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeliveryAttemptReceipt",
  "type": "object",
  "required": [
    "schema_version",
    "attempt_id",
    "job_id",
    "book_id",
    "run_id",
    "publication_receipt_hash",
    "payload_hash",
    "target_type",
    "worker_id",
    "previous_state",
    "outcome",
    "query_only",
    "remote_mutation_started",
    "started_at",
    "finished_at",
    "diagnostics",
    "attempt_receipt_hash"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "attempt_id": {"type": "string", "minLength": 1},
    "job_id": {"type": "string", "minLength": 1},
    "book_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "publication_receipt_hash": {"type": "string", "minLength": 64},
    "payload_hash": {"type": "string", "minLength": 64},
    "target_type": {"type": "string", "minLength": 1},
    "worker_id": {"type": "string", "minLength": 1},
    "previous_state": {"type": "string", "minLength": 1},
    "outcome": {"type": "object", "additionalProperties": true},
    "query_only": {"type": "boolean"},
    "remote_mutation_started": {"type": "boolean"},
    "started_at": {"type": "string", "minLength": 1},
    "finished_at": {"type": "string", "minLength": 1},
    "diagnostics": {"type": "object", "additionalProperties": true},
    "attempt_receipt_hash": {"type": "string", "minLength": 64}
  },
  "additionalProperties": false
}
