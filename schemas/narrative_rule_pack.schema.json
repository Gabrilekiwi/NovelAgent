{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Narrative Rule Pack",
  "type": "object",
  "required": [
    "schema_version",
    "rule_pack_id",
    "title",
    "language",
    "version",
    "rules",
    "output_contract",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "rule_pack_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "code",
          "category",
          "severity",
          "enabled",
          "title",
          "instruction",
          "applies_to"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "continuity",
              "character",
              "spatial",
              "conflict",
              "foreshadowing",
              "style",
              "language",
              "output_contract",
              "pacing",
              "safety",
              "custom"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "enabled": {
            "type": "boolean"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "instruction": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string"
          },
          "applies_to": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["generation", "evaluation", "validation", "repair"]
            }
          },
          "quality_check_codes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "examples": {
            "type": "object",
            "properties": {
              "good": {
                "type": "string"
              },
              "bad": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "output_contract": {
      "type": "object",
      "required": ["must_output", "must_not_output"],
      "properties": {
        "must_output": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "must_not_output": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
