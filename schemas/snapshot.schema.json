{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Snapshot",
  "type": "object",
  "required": ["chapter_index", "world_state", "characters", "timeline", "story_state", "spatial_state"],
  "properties": {
    "book_id": {
      "type": "string",
      "minLength": 1
    },
    "chapter_index": {
      "type": "integer",
      "minimum": 1
    },
    "world_state": {
      "type": "object",
      "properties": {
        "locations": {
          "type": "object"
        },
        "last_world_changes": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "characters": {
      "type": "object"
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "story_state": {
      "type": "object",
      "required": [
        "last_chapter_ending",
        "last_scene_location",
        "last_scene_characters",
        "open_threads",
        "required_opening_bridge"
      ],
      "properties": {
        "last_chapter_ending": {
          "type": "string"
        },
        "last_scene_location": {
          "type": "string"
        },
        "last_scene_characters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_threads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_opening_bridge": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "spatial_state": {
      "type": "object",
      "required": [
        "spaces",
        "connections",
        "character_positions",
        "blocked_paths",
        "last_transition"
      ],
      "properties": {
        "spaces": {
          "type": "object"
        },
        "connections": {
          "type": "array"
        },
        "character_positions": {
          "type": "object"
        },
        "blocked_paths": {
          "type": "array"
        },
        "last_transition": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "constraints": {
      "type": "array"
    },
    "memory": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
