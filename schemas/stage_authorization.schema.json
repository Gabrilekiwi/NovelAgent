{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StageAuthorization",
  "type": "object",
  "required": ["schema_version", "authorization_hash", "stage", "book_id", "session_id", "plan_id", "chapter_index", "authority", "input_digest", "previous_stage_receipt_hash", "provider_profile", "max_output_tokens", "issued_at"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0", "1.1"]},
    "authorization_hash": {"type": "string", "minLength": 64},
    "stage": {"type": "string", "enum": ["outline", "scene_plan", "draft", "polish", "validator", "repair"]},
    "book_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "plan_id": {"type": "string", "minLength": 1},
    "chapter_index": {"type": "integer", "minimum": 1},
    "authority": {
      "type": "object",
      "required": ["epoch", "head_event_hash"],
      "properties": {
        "epoch": {"type": "integer", "minimum": 0},
        "head_event_hash": {"type": ["string", "null"], "minLength": 64}
      },
      "additionalProperties": false
    },
    "input_digest": {"type": "string", "minLength": 64},
    "previous_stage_receipt_hash": {"type": ["string", "null"], "minLength": 64},
    "provider_profile": {"type": "string", "minLength": 1},
    "max_output_tokens": {"type": "integer", "minimum": 1},
    "execution_kind": {"type": "string", "enum": ["model", "deterministic"]},
    "issued_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
