{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Regression Manifest",
  "type": "object",
  "required": ["schema_version", "suite_id", "title", "cases"],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "suite_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "title",
          "category",
          "snapshot_path",
          "previous_chapter_path",
          "chapter_path",
          "expected_path"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "snapshot_path": {
            "type": "string",
            "minLength": 1
          },
          "previous_chapter_path": {
            "type": "string",
            "minLength": 1
          },
          "chapter_path": {
            "type": "string",
            "minLength": 1
          },
          "expected_path": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
