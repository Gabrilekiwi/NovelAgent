{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CanonicalMemory",
  "type": "object",
  "required": [
    "schema_version",
    "revision",
    "book_id",
    "title",
    "language",
    "world",
    "current_state",
    "characters",
    "locations",
    "timeline",
    "open_threads",
    "chapter_states",
    "constraints",
    "style_rules",
    "source_index",
    "source_resolution",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "2.0"
      ]
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "book_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "world": {
      "type": "object"
    },
    "current_state": {
      "type": "object"
    },
    "characters": {
      "type": "object"
    },
    "locations": {
      "type": "object"
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "summary",
          "data"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "chapter_index": {
            "type": "integer",
            "minimum": 0
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "data": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "open_threads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "data"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "closed"
            ]
          },
          "data": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "chapter_states": {
      "type": "object"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "status",
          "data"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "resolved"
            ]
          },
          "data": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "style_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "rule",
          "status",
          "data"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive"
            ]
          },
          "data": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "source_index": {
      "type": "object"
    },
    "source_resolution": {
      "type": "object"
    },
    "metadata": {
      "type": "object",
      "required": [
        "source",
        "created_by"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "created_by": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
