{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CanonicalMemory",
  "type": "object",
  "required": [
    "schema_version",
    "book_id",
    "title",
    "language",
    "world",
    "characters",
    "locations",
    "timeline",
    "constraints",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "2.0"
      ]
    },
    "book_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "world": {
      "type": "object"
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "data"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "data": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "data"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "data": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "summary",
          "data"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "chapter_index": {
            "type": "integer",
            "minimum": 0
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "data": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "status",
          "data"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "resolved"
            ]
          },
          "data": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "source",
        "created_by"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "created_by": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
