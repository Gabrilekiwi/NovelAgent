{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PersistenceRegistryEntry",
  "type": "object",
  "required": [
    "schema_version",
    "book_id",
    "run_id",
    "state",
    "journal_relative_path",
    "manifest_digest",
    "registered_at"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["2.0", "2.1"]},
    "book_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "state": {
      "type": "string",
      "enum": ["pending", "completed", "rolled_back", "recovery_required"]
    },
    "journal_relative_path": {"type": "string", "minLength": 1},
    "manifest_digest": {"type": "string", "minLength": 64},
    "registered_at": {"type": "string", "minLength": 1},
    "receipt": {"type": ["object", "null"]},
    "error_count": {"type": "integer", "minimum": 0}
  },
  "additionalProperties": false
}
