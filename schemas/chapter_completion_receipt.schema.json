{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterCompletionReceipt",
  "type": "object",
  "required": ["schema_version", "receipt_hash", "book_id", "session_id", "plan_id", "arc_plan_id", "chapter_index", "planned_target_hash", "chapter_body_hash", "final_stage_receipt_hash", "publication_receipt_hash", "lease_hash", "lease_generation", "source_snapshot_after", "previous_completion_receipt_hash", "status", "created_at"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "receipt_hash": {"type": "string", "minLength": 64},
    "book_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "plan_id": {"type": "string", "minLength": 1},
    "arc_plan_id": {"type": "string", "minLength": 1},
    "chapter_index": {"type": "integer", "minimum": 1},
    "planned_target_hash": {"type": "string", "minLength": 64},
    "chapter_body_hash": {"type": "string", "minLength": 64},
    "final_stage_receipt_hash": {"type": "string", "minLength": 64},
    "publication_receipt_hash": {"type": "string", "minLength": 64},
    "lease_hash": {"type": "string", "minLength": 64},
    "lease_generation": {"type": "integer", "minimum": 1},
    "source_snapshot_after": {
      "type": "object",
      "required": ["schema_version", "book_id", "root_uuid", "authority_epoch", "authority_head_event_hash", "canonical_next_chapter", "source_digest", "captured_at", "snapshot_hash"],
      "properties": {
        "schema_version": {"type": "string", "enum": ["1.0"]},
        "book_id": {"type": "string", "minLength": 1},
        "root_uuid": {"type": "string", "minLength": 1},
        "authority_epoch": {"type": "integer", "minimum": 0},
        "authority_head_event_hash": {"type": ["string", "null"], "minLength": 64},
        "canonical_next_chapter": {"type": "integer", "minimum": 1},
        "source_digest": {"type": "string", "minLength": 64},
        "captured_at": {"type": "string", "minLength": 1},
        "snapshot_hash": {"type": "string", "minLength": 64}
      },
      "additionalProperties": false
    },
    "previous_completion_receipt_hash": {"type": ["string", "null"], "minLength": 64},
    "status": {"type": "string", "enum": ["committed", "local_committed_delivery_blocked"]},
    "created_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
