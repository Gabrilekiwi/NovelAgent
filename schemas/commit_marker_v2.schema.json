{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommitMarkerV2",
  "type": "object",
  "required": [
    "schema_version",
    "book_id",
    "run_id",
    "manifest",
    "manifest_digest",
    "candidate_digest",
    "artifact_bundle_digest",
    "final_run_hash",
    "apply_target_bundle_digest",
    "canonical_json_algorithm",
    "marked_at",
    "marker_hash"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["2.0", "2.1"]},
    "book_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "manifest": {"type": "object", "additionalProperties": true},
    "manifest_digest": {"type": "string", "minLength": 64},
    "candidate_digest": {"type": "string", "minLength": 64},
    "artifact_bundle_digest": {"type": "string", "minLength": 64},
    "final_run_hash": {"type": "string", "minLength": 64},
    "apply_target_bundle_digest": {"type": "string", "minLength": 64},
    "canonical_json_algorithm": {"type": "string", "minLength": 1},
    "marked_at": {"type": "string", "minLength": 1},
    "marker_hash": {"type": "string", "minLength": 64}
  },
  "additionalProperties": false
}
