{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeliveryIntent",
  "type": "object",
  "required": ["schema_version", "intent_id", "intent_hash", "book_id", "run_id", "chapter_index", "target_type", "profile_id", "target", "policy", "canonical_payload", "job_payload_hash", "created_at"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "intent_id": {"type": "string", "minLength": 1},
    "intent_hash": {"type": "string", "minLength": 64},
    "book_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "chapter_index": {"type": "integer", "minimum": 1},
    "target_type": {"type": "string", "enum": ["file"]},
    "profile_id": {"type": "string", "minLength": 1},
    "target": {"type": "object", "additionalProperties": true},
    "policy": {"type": "string", "enum": ["required", "best_effort"]},
    "canonical_payload": {"type": "object", "additionalProperties": true},
    "job_payload_hash": {"type": "string", "minLength": 64},
    "created_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
