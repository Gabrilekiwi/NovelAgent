{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DirectorAudit",
  "type": "object",
  "required": ["mode", "source", "model", "status", "started_at", "finished_at", "duration_ms"],
  "properties": {
    "mode": {
      "enum": ["rule", "model", "injected", "unknown"]
    },
    "source": {
      "type": "string"
    },
    "model": {
      "type": ["string", "null"]
    },
    "status": {
      "enum": ["completed", "failed"]
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "error_type": {
      "type": "string"
    },
    "error_message": {
      "type": "string"
    },
    "provider_attempts": {
      "type": "array",
      "items": {"type": "object"}
    },
    "model_call": {
      "type": "object",
      "required": ["provider", "stage", "model", "cause_type", "message"],
      "properties": {
        "provider": {
          "type": "string"
        },
        "stage": {
          "type": "string"
        },
        "model": {
          "type": ["string", "null"]
        },
        "cause_type": {
          "type": ["string", "null"]
        },
        "message": {
          "type": "string"
        },
        "failure_category": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        },
        "attempts": {
          "type": "integer",
          "minimum": 1
        },
        "elapsed_ms": {
          "type": "integer",
          "minimum": 0
        },
        "attempt_history": {
          "type": "array",
          "items": {"type": "object"}
        },
        "retry_stop_reason": {
          "type": "string",
          "enum": [
            "non_retryable",
            "max_attempts",
            "deadline_exhausted",
            "run_budget_exhausted",
            "partial_content_received"
          ]
        },
        "partial_content_received": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
