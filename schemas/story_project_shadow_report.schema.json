{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryProjectShadowReport",
  "type": "object",
  "required": [
    "schema_version",
    "mode",
    "authoritative",
    "affects_generation",
    "affects_snapshot",
    "book_id",
    "chapter_index",
    "state",
    "differences",
    "blocking_conflict_count",
    "warning_count",
    "strict_eligible",
    "strict_blockers"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "mode": {
      "type": "string",
      "enum": ["shadow"]
    },
    "authoritative": {
      "type": "boolean",
      "enum": [false]
    },
    "affects_generation": {
      "type": "boolean",
      "enum": [false]
    },
    "affects_snapshot": {
      "type": "boolean",
      "enum": [false]
    },
    "book_id": {
      "type": "string",
      "minLength": 1
    },
    "chapter_index": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "type": "object"
    },
    "differences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field_path", "semantic_value", "snapshot_value"],
        "properties": {
          "field_path": {
            "type": "string",
            "minLength": 1
          },
          "semantic_value": {
            "type": ["object", "array", "string", "integer", "number", "boolean", "null"]
          },
          "snapshot_value": {
            "type": ["object", "array", "string", "integer", "number", "boolean", "null"]
          }
        },
        "additionalProperties": false
      }
    },
    "blocking_conflict_count": {
      "type": "integer",
      "minimum": 0
    },
    "warning_count": {
      "type": "integer",
      "minimum": 0
    },
    "strict_eligible": {
      "type": "boolean",
      "enum": [false]
    },
    "strict_blockers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
