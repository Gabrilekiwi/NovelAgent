{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ModelCallIntent",
  "type": "object",
  "required": [
    "schema_version",
    "canonical_json_algorithm",
    "call_id",
    "attempt_id",
    "request_digest",
    "provider",
    "model",
    "stage",
    "budget_reservation",
    "created_at",
    "intent_hash"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "canonical_json_algorithm": {"type": "string", "enum": ["novelagent-canonical-json-v1"]},
    "call_id": {"type": "string", "minLength": 1},
    "attempt_id": {"type": "string", "minLength": 1},
    "request_digest": {"type": "string", "minLength": 64},
    "provider": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "stage": {"type": "string", "minLength": 1},
    "budget_reservation": {"type": "object", "additionalProperties": true},
    "created_at": {"type": "string", "minLength": 1},
    "intent_hash": {"type": "string", "minLength": 64}
  },
  "additionalProperties": false
}
