{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PublicationReceipt",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_id",
    "receipt_path_ref",
    "book_id",
    "run_id",
    "context_digest",
    "generation_input_context_digest",
    "story_project_source_revision_after",
    "manifest",
    "marker",
    "candidate_digest",
    "artifact_bundle_digest",
    "final_run",
    "artifacts",
    "apply_targets",
    "delivery_jobs",
    "canonical_json_algorithm",
    "published_at",
    "receipt_hash"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["2.0", "2.1"]},
    "receipt_id": {"type": "string", "minLength": 1},
    "receipt_path_ref": {"type": "object", "additionalProperties": true},
    "book_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "context_digest": {"type": "string", "minLength": 64},
    "generation_input_context_digest": {"type": "string", "minLength": 64},
    "story_project_source_revision_after": {"type": "object", "additionalProperties": true},
    "manifest": {"type": "object", "additionalProperties": true},
    "marker": {"type": "object", "additionalProperties": true},
    "candidate_digest": {"type": "string", "minLength": 64},
    "artifact_bundle_digest": {"type": "string", "minLength": 64},
    "final_run": {"type": "object", "additionalProperties": true},
    "artifacts": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "apply_targets": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "delivery_jobs": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "canonical_json_algorithm": {"type": "string", "minLength": 1},
    "published_at": {"type": "string", "minLength": 1},
    "receipt_hash": {"type": "string", "minLength": 64}
  },
  "additionalProperties": false
}
