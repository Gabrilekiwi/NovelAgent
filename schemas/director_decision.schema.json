{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DirectorDecision",
  "type": "object",
  "required": [
    "chapter_index",
    "goal",
    "actions",
    "validation_focus",
    "max_repair_attempts",
    "notes"
  ],
  "properties": {
    "chapter_index": {
      "type": "integer",
      "minimum": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "build_snapshot",
          "pre_validate_bridge",
          "generate_chapter",
          "polish",
          "validate",
          "repair_if_needed",
          "commit_snapshot"
        ]
      }
    },
    "validation_focus": {
      "type": "array",
      "items": {
        "enum": [
          "continuity",
          "spatial",
          "logic"
        ]
      }
    },
    "max_repair_attempts": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
