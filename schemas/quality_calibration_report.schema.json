{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QualityCalibrationReport",
  "type": "object",
  "required": [
    "schema_version",
    "fixture_id",
    "fixture_source",
    "fixture_sha256",
    "sample_counts",
    "policy",
    "holdout_metrics",
    "acceptance_checks",
    "gender_contradiction",
    "passed",
    "report_sha256"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "fixture_id": {"type": "string", "minLength": 1},
    "fixture_source": {
      "type": "string",
      "enum": ["synthetic_acceptance_v1", "synthetic_raw_production_v1"]
    },
    "fixture_sha256": {"type": "string", "minLength": 64},
    "sample_counts": {
      "type": "object",
      "required": ["total", "calibration_set", "holdout_set"],
      "properties": {
        "total": {"type": "integer", "minimum": 60},
        "calibration_set": {"type": "integer", "minimum": 1},
        "holdout_set": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": [
        "schema_version",
        "fixture_id",
        "fixture_source",
        "blocking_threshold",
        "threshold_source",
        "calibration_sample_ids",
        "calibration_sha256",
        "criteria",
        "calibration_metrics",
        "policy_sha256"
      ],
      "properties": {
        "schema_version": {"type": "string", "enum": ["1.0"]},
        "fixture_id": {"type": "string", "minLength": 1},
        "fixture_source": {
          "type": "string",
          "enum": ["synthetic_acceptance_v1", "synthetic_raw_production_v1"]
        },
        "blocking_threshold": {
          "type": "string",
          "enum": ["warning", "medium", "high", "critical"]
        },
        "threshold_source": {"type": "string", "enum": ["calibration_set"]},
        "calibration_sample_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "calibration_sha256": {"type": "string", "minLength": 64},
        "criteria": {
          "type": "object",
          "required": [
            "blocking_precision_min",
            "critical_high_recall_min",
            "clean_false_block_rate_max"
          ],
          "properties": {
            "blocking_precision_min": {"type": "number", "minimum": 0, "maximum": 1},
            "critical_high_recall_min": {"type": "number", "minimum": 0, "maximum": 1},
            "clean_false_block_rate_max": {"type": "number", "minimum": 0, "maximum": 1}
          },
          "additionalProperties": false
        },
        "calibration_metrics": {
          "type": "object",
          "required": [
            "sample_count",
            "true_positive",
            "false_positive",
            "false_negative",
            "true_negative",
            "blocking_precision",
            "critical_high_recall",
            "clean_false_block_rate"
          ],
          "properties": {
            "sample_count": {"type": "integer", "minimum": 1},
            "true_positive": {"type": "integer", "minimum": 0},
            "false_positive": {"type": "integer", "minimum": 0},
            "false_negative": {"type": "integer", "minimum": 0},
            "true_negative": {"type": "integer", "minimum": 0},
            "blocking_precision": {"type": "number", "minimum": 0, "maximum": 1},
            "critical_high_recall": {"type": "number", "minimum": 0, "maximum": 1},
            "clean_false_block_rate": {"type": "number", "minimum": 0, "maximum": 1}
          },
          "additionalProperties": false
        },
        "policy_sha256": {"type": "string", "minLength": 64}
      },
      "additionalProperties": false
    },
    "holdout_metrics": {
      "type": "object",
      "required": [
        "sample_count",
        "true_positive",
        "false_positive",
        "false_negative",
        "true_negative",
        "blocking_precision",
        "critical_high_recall",
        "clean_false_block_rate"
      ],
      "properties": {
        "sample_count": {"type": "integer", "minimum": 1},
        "true_positive": {"type": "integer", "minimum": 0},
        "false_positive": {"type": "integer", "minimum": 0},
        "false_negative": {"type": "integer", "minimum": 0},
        "true_negative": {"type": "integer", "minimum": 0},
        "blocking_precision": {"type": "number", "minimum": 0, "maximum": 1},
        "critical_high_recall": {"type": "number", "minimum": 0, "maximum": 1},
        "clean_false_block_rate": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "acceptance_checks": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["name", "comparator", "actual", "target", "passed"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["blocking_precision", "critical_high_recall", "clean_false_block_rate"]
          },
          "comparator": {"type": "string", "enum": [">=", "<="]},
          "actual": {"type": "number", "minimum": 0, "maximum": 1},
          "target": {"type": "number", "minimum": 0, "maximum": 1},
          "passed": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "gender_contradiction": {
      "type": "object",
      "required": ["case_ids", "detected_ids", "passed"],
      "properties": {
        "case_ids": {
          "type": "array",
          "minItems": 2,
          "items": {"type": "string", "minLength": 1}
        },
        "detected_ids": {
          "type": "array",
          "minItems": 2,
          "items": {"type": "string", "minLength": 1}
        },
        "passed": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "passed": {"type": "boolean"},
    "report_sha256": {"type": "string", "minLength": 64}
  },
  "additionalProperties": false
}
