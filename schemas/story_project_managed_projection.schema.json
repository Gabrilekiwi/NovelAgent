{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryProjectManagedProjection",
  "type": "object",
  "required": [
    "schema_version",
    "scope",
    "book_id",
    "run_id",
    "chapter",
    "parser_version",
    "base_revision",
    "base_source_digest",
    "owned_fields",
    "values",
    "tombstones",
    "payload_sha256"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "scope": {"type": "string", "enum": ["context", "character_state", "foreshadowing", "timeline"]},
    "book_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "chapter": {"type": "integer", "minimum": 1},
    "parser_version": {"type": "string", "minLength": 1},
    "base_revision": {"type": "string", "minLength": 1},
    "base_source_digest": {"type": "string", "minLength": 64},
    "owned_fields": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "values": {"type": "object", "additionalProperties": true},
    "tombstones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field_path", "reason"],
        "properties": {
          "field_path": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1},
          "superseded_by": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "payload_sha256": {"type": "string", "minLength": 64}
  },
  "additionalProperties": false
}
