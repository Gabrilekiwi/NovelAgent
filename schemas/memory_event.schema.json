{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryEvent",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "revision",
    "op",
    "source",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "2.0"
      ]
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "op": {
      "type": "string",
      "minLength": 1
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "field": {
      "type": "string",
      "minLength": 1
    },
    "old_value": {
      "type": [
        "object",
        "array",
        "string",
        "integer",
        "number",
        "boolean",
        "null"
      ]
    },
    "new_value": {
      "type": [
        "object",
        "array",
        "string",
        "integer",
        "number",
        "boolean",
        "null"
      ]
    },
    "source": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string"
        },
        "patch_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_by": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
