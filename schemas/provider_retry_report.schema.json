{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProviderRetryReport",
  "type": "object",
  "required": [
    "schema_version",
    "profile",
    "max_attempts",
    "attempts",
    "completed",
    "stop_reason",
    "elapsed_ms",
    "history"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "profile": {
      "type": "string",
      "enum": ["model_read_generation", "claude_polish", "notion_read_query", "notion_create"]
    },
    "max_attempts": {"type": "integer", "minimum": 1},
    "attempts": {"type": "integer", "minimum": 1},
    "completed": {"type": "boolean"},
    "stop_reason": {
      "type": "string",
      "enum": [
        "succeeded",
        "non_retryable",
        "max_attempts",
        "deadline_exhausted",
        "run_budget_exhausted",
        "partial_content_received"
      ]
    },
    "elapsed_ms": {"type": "integer", "minimum": 0},
    "history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "attempt",
          "outcome",
          "failure_category",
          "retryable",
          "partial_content_received",
          "cause_type",
          "elapsed_ms",
          "delay_ms",
          "retry_after_ms"
        ],
        "properties": {
          "attempt": {"type": "integer", "minimum": 1},
          "outcome": {"type": "string", "enum": ["succeeded", "failed"]},
          "failure_category": {"type": ["string", "null"]},
          "retryable": {"type": "boolean"},
          "partial_content_received": {"type": "boolean"},
          "cause_type": {"type": ["string", "null"]},
          "elapsed_ms": {"type": "integer", "minimum": 0},
          "delay_ms": {"type": "integer", "minimum": 0},
          "retry_after_ms": {"type": ["integer", "null"], "minimum": 0}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
