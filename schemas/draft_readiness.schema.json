{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DraftReadiness",
  "type": "object",
  "required": ["schema_version", "kind", "ok", "reasons", "book_id", "session_id", "plan_id", "chapter_index", "authority", "context_digest", "outline_hash", "outline_stage_receipt_hash", "checked_at", "evidence"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "kind": {"type": "string", "enum": ["draft"]},
    "ok": {"type": "boolean"},
    "reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "book_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "plan_id": {"type": "string", "minLength": 1},
    "chapter_index": {"type": "integer", "minimum": 1},
    "authority": {
      "type": "object",
      "required": ["epoch", "head_event_hash"],
      "properties": {
        "epoch": {"type": "integer", "minimum": 0},
        "head_event_hash": {"type": ["string", "null"], "minLength": 64}
      },
      "additionalProperties": false
    },
    "context_digest": {"type": "string", "minLength": 64},
    "outline_hash": {"type": "string", "minLength": 64},
    "outline_stage_receipt_hash": {"type": "string", "minLength": 64},
    "checked_at": {"type": "string", "minLength": 1},
    "evidence": {
      "type": "object",
      "required": ["outline_receipt_valid", "book_matches", "outline_hash_matches", "authority_matches", "context_matches", "session_matches", "plan_matches", "chapter_matches"],
      "properties": {
        "outline_receipt_valid": {"type": "boolean"},
        "book_matches": {"type": "boolean"},
        "outline_hash_matches": {"type": "boolean"},
        "authority_matches": {"type": "boolean"},
        "context_matches": {"type": "boolean"},
        "session_matches": {"type": "boolean"},
        "plan_matches": {"type": "boolean"},
        "chapter_matches": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
