{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LlmValidationResult",
  "type": "object",
  "required": ["problems"],
  "properties": {
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message", "area", "severity", "fact_id", "evidence", "repair_hint"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "area": {
            "enum": [
              "complex_plot_logic",
              "character_motivation_consistency",
              "timeline_causality",
              "setup_and_payoff",
              "emotional_and_theme_drift"
            ]
          },
          "severity": {
            "enum": ["critical", "high", "medium", "low"]
          },
          "fact_id": {
            "type": "string",
            "minLength": 79
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kind", "start_char", "end_char", "quote"],
              "properties": {
                "kind": {
                  "enum": ["chapter_span"]
                },
                "start_char": {
                  "type": "integer",
                  "minimum": 0
                },
                "end_char": {
                  "type": "integer",
                  "minimum": 1
                },
                "quote": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            }
          },
          "repair_hint": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
