{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NextStepContextPreflight",
  "type": "object",
  "required": [
    "schema_version",
    "valid",
    "book_id",
    "next_chapter",
    "next_step_context_digest",
    "checks",
    "blocking_conflicts"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "valid": {"type": "boolean"},
    "book_id": {"type": "string", "minLength": 1},
    "next_chapter": {"type": "integer", "minimum": 1},
    "next_step_context_digest": {"type": "string", "minLength": 64},
    "checks": {
      "type": "object",
      "required": [
        "unique_next_chapter_outline",
        "current_story_project_sources",
        "project_identity_matches",
        "parser_qualified",
        "blocking_conflicts_absent"
      ],
      "properties": {
        "unique_next_chapter_outline": {"type": "boolean"},
        "current_story_project_sources": {"type": "boolean"},
        "project_identity_matches": {"type": "boolean"},
        "parser_qualified": {"type": "boolean"},
        "blocking_conflicts_absent": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "blocking_conflicts": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "additionalProperties": true
}
