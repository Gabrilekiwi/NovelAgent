{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TrustedProfiles",
  "type": "object",
  "required": ["schema_version", "profile_set_id", "story_projects", "provider_models", "file_deliveries", "budgets", "quality_policies", "defaults"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "profile_set_id": {"type": "string", "minLength": 1},
    "story_projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["profile_id", "book_id", "root_uuid"],
        "properties": {
          "profile_id": {"type": "string", "minLength": 1},
          "book_id": {"type": "string", "minLength": 1},
          "root_uuid": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "provider_models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["profile_id", "provider", "model", "max_output_tokens"],
        "properties": {
          "profile_id": {"type": "string", "minLength": 1},
          "provider": {"type": "string", "enum": ["openai", "anthropic"]},
          "endpoint_type": {"type": "string", "enum": ["official", "openai_compatible"]},
          "model": {"type": "string", "minLength": 1},
          "max_output_tokens": {"type": "integer", "minimum": 1}
        },
        "additionalProperties": false
      }
    },
    "file_deliveries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["profile_id", "target_kind", "root_uuid", "path_template", "requires_run_id", "requires_chapter_id"],
        "properties": {
          "profile_id": {"type": "string", "minLength": 1},
          "target_kind": {"type": "string", "enum": ["file"]},
          "root_uuid": {"type": "string", "minLength": 1},
          "path_template": {"type": "string", "minLength": 1},
          "requires_run_id": {"type": "boolean"},
          "requires_chapter_id": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "budgets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["profile_id", "max_chapters", "max_model_calls", "max_input_tokens", "max_output_tokens", "max_wall_seconds"],
        "properties": {
          "profile_id": {"type": "string", "minLength": 1},
          "max_chapters": {"type": "integer", "minimum": 1},
          "max_model_calls": {"type": "integer", "minimum": 1},
          "max_input_tokens": {"type": "integer", "minimum": 1},
          "max_output_tokens": {"type": "integer", "minimum": 1},
          "max_wall_seconds": {"type": "integer", "minimum": 1}
        },
        "additionalProperties": false
      }
    },
    "quality_policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["profile_id", "policy", "minimum_score"],
        "properties": {
          "profile_id": {"type": "string", "minLength": 1},
          "policy": {"type": "string", "enum": ["minimal", "standard", "strict"]},
          "minimum_score": {"type": "integer", "enum": [0]}
        },
        "additionalProperties": false
      }
    },
    "defaults": {
      "type": "object",
      "required": ["story_project", "provider_model", "file_delivery", "budget", "quality_policy"],
      "properties": {
        "story_project": {"type": "string", "minLength": 1},
        "provider_model": {"type": "string", "minLength": 1},
        "file_delivery": {"type": "string", "minLength": 1},
        "budget": {"type": "string", "minLength": 1},
        "quality_policy": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
