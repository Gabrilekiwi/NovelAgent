{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalysisResult",
  "type": "object",
  "required": [
    "summary",
    "events",
    "character_changes",
    "world_changes",
    "new_locations",
    "conflicts",
    "validation_ok"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          }
        }
      }
    },
    "character_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "current_location": {
            "type": "string"
          },
          "current_goal": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      }
    },
    "world_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      }
    },
    "new_locations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_ok": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
