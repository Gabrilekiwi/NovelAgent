{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalysisResult",
  "type": "object",
  "required": [
    "summary",
    "events",
    "character_changes",
    "world_changes",
    "new_locations",
    "conflicts",
    "validation_ok"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          }
        }
      }
    },
    "character_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "current_location": {
            "type": "string"
          },
          "current_goal": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      }
    },
    "world_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      }
    },
    "new_locations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "story_state": {
      "type": "object",
      "required": [
        "last_chapter_ending",
        "last_scene_location",
        "last_scene_characters",
        "open_threads",
        "required_opening_bridge"
      ],
      "properties": {
        "last_chapter_ending": {
          "type": "string"
        },
        "last_scene_location": {
          "type": "string"
        },
        "last_scene_characters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_threads": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_opening_bridge": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "spatial_state": {
      "type": "object",
      "required": [
        "spaces",
        "connections",
        "character_positions",
        "blocked_paths",
        "last_transition"
      ],
      "properties": {
        "spaces": {
          "type": "object"
        },
        "connections": {
          "type": "array"
        },
        "character_positions": {
          "type": "object"
        },
        "blocked_paths": {
          "type": "array"
        },
        "last_transition": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_ok": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
